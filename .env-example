# Copie:  copy .env-example .env   (Windows)
#         cp .env-example .env     (Linux/macOS)

ORGANIZATION=OrganizationName

# ---------------------------------------------------------------
# Autenticacao Microsoft Entra ID - sem PAT
# ---------------------------------------------------------------
# AUTH_MODE=cli    -> token via Azure CLI (az login no terminal)
# AUTH_MODE=oauth  -> OAuth Authorization Code + PKCE (requer App Registration no Portal)
# AUTH_MODE=device -> Device Code no navegador (Docker, sem Portal Azure)
AUTH_MODE=device

# Tenant do Entra ID - GUID em portal.azure.com > Microsoft Entra ID > Overview
TENANT_ID=00000000-0000-0000-0000-000000000000

# Application client ID do App Registration - obrigatorio no modo oauth
# Nao precisa preencher no modo device (client ID publico da Microsoft)
CLIENT_ID=

# Redirect URI registrada no App Registration - modo oauth
REDIRECT_URI="http://localhost:8080/callback.php"

# Chave para criptografar o token (modos oauth e device)
# Gere com: php -r "echo bin2hex(random_bytes(32));"
APP_KEY=

# Timeout em segundos e tentativas de retry das chamadas HTTP
HTTP_TIMEOUT=30
HTTP_RETRIES=3

# ---------------------------------------------------------------
# API Azure DevOps
# ---------------------------------------------------------------
URL_TASKS="https://dev.azure.com/%s/_apis/wit/workitems?ids=%s&fields=System.Id,System.Title,System.WorkItemType,System.State,Microsoft.VSTS.Scheduling.CompletedWork,Microsoft.VSTS.Scheduling.OriginalEstimate,System.Parent,System.AreaPath,Custom.Prazoss,System.AssignedTo,System.TeamProject,Microsoft.VSTS.Common.Activity&api-version=7.1"
URL_LIST_TASKS="https://dev.azure.com/%s/%s/_apis/wit/wiql?api-version=7.1"
PROJECT_DEFAULT=CUIABA-MT-BRASIL
PROJECTS=SITE-NOVO,CONTROLE-FINANCEIRO
EMAIL_DEV=NOME.SOBRENOME@domain.com.br
TEMPO_RECARREGAR_PAGINA_MINUTOS=30
URL_ACCESS="https://dev.azure.com/%s/%s/_workitems/edit/%s/"
REQUEST_ONLINE=TRUE
APP_DEBUG=TRUE
